{
  "editor.fontFamily": "Iosevka Nerd Font, Iosevka, Menlo, Monaco, 'Courier New', monospace",
  "editor.fontLigatures": true,
  // Controls how the editor should render whitespace characters, possibilities are 'none', 'boundary', and 'all'. The 'boundary' option does not render single spaces between words.
  "editor.renderWhitespace": "all",
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.snippetSuggestions": "top",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/*.pyc": {
      "when": "$(basename).py",
    },
    "**/*.ipynb_checkpoints": true,
  },
  // When enabled, will trim trailing whitespace when saving a file.
  "files.trimTrailingWhitespace": true,
  "editor.rulers": [80, 88, 120, 150],
  // Folders to look into for virtual environments.
  "python.venvFolders": [".env", "envs", ".pyenv", ".direnv", ".venv"],
  // Path to folder with a list of Virtual Environments (e.g. ~/.pyenv, ~/Envs, ~/.virtualenvs).
  "python.venvPath": "~/.virtualenvs",
  "editor.minimap.enabled": false,
  "prettier.singleQuote": true,
  "window.closeWhenEmpty": true,
  "editor.detectIndentation": true,
  "editor.showFoldingControls": "always",
  "editor.find.seedSearchStringFromSelection": true,
  "editor.useTabStops": false,
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome",
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode",
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome",
  },
  "[html]": {
    "editor.defaultFormatter": "biomejs.biome",
  },
  "[markdown]": {
    "editor.wordWrap": "off",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[python]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit",
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "notebook.formatOnSave.enabled": true,
  "notebook.codeActionsOnSave": {
    "source.fixAll": false,
    "source.organizeImports": false,
  },
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
  },
  "npm.enableRunFromFolder": true,
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left",
  },
  "notebook.lineNumbers": "on",
  "editor.inlineSuggest.enabled": true,
  "cSpell.userWords": [
    "beauhurst",
    "deepinfra",
    "direnv",
    "dorzey",
    "esbenp",
    "Giacometti",
    "Iosevka",
    "ipdb",
    "ipykernel",
    "ipynb",
    "isort",
    "noqa",
    "pyarrow",
    "pyenv",
    "pylint",
    "sqlfluff",
    "timezone",
    "venv",
    "virtualenv",
    "virtualenvs",
  ],
  "cSpell.language": "en-GB",
  "github.copilot.enable": {
    "quarto": true,
    "*": true,
    "yaml": true,
    "plaintext": true,
    "markdown": true,
  },
  "workbench.colorTheme": "Ayu Mirage",
  "editor.minimap.renderCharacters": false,
  "workbench.preferredDarkColorTheme": "Ayu Mirage",
  "explorer.confirmDelete": false,
  "jupyter.askForKernelRestart": false,
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome",
  },
  "editor.stickyScroll.enabled": true,
  "githubPullRequests.pullBranch": "never",
  "editor.accessibilitySupport": "off",
  "[sql]": {
    "editor.defaultFormatter": "dorzey.vscode-sqlfluff",
  },
  "sqlfluff.dialect": "postgres",
  "svelte.enable-ts-plugin": true,
  "editor.fontSize": 13,
  "sqltools.connections": [],

  "files.associations": {
    ".env.yml": "yaml",
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
  },
  "quarto.visualEditor.spellingDictionary": "en_GB",
  "quarto.render.renderOnSave": true,
  "extensions.ignoreRecommendations": true,
  "redhat.telemetry.enabled": false,
  "shellcheck.disableVersionCheck": true,
  "telemetry.telemetryLevel": "off",
  "update.showReleaseNotes": false,
  "workbench.welcomePage.walkthroughs.openOnInstall": false,
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.preferredLightColorTheme": "Ayu Light",
  "oneDarkPro.editorTheme": "Ayu",
  "workbench.iconTheme": "ayu",
  "workbench.preferredHighContrastColorTheme": "Ayu Dark",
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  "zig.path": "zig",
  "zig.zls.path": "zls",
  "github.copilot.editor.enableAutoCompletions": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "liveshare.launcherClient": "visualStudioCode",
  "liveshare.accessibility.voice": "en-GB-Libby",
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome",
  },
  "continue.telemetryEnabled": false,
  "docker.extension.enableComposeLanguageServer": false,
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true,
    },
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "zig.zls.enabled": "on",
  "terminal.integrated.stickyScroll.enabled": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "[skill]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.wordWrap": "off",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "on",
      "other": "on"
    },
    "editor.wordBasedSuggestions": "off"
  },
  "terminal.integrated.defaultLocation": "editor",
}
